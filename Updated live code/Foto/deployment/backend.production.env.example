PORT=4000
NODE_ENV=production
CLIENT_ORIGIN=https://your-frontend-domain.example
JWT_SECRET=replace-with-a-long-random-secret
DATA_PROVIDER=mongo
STORAGE_PROVIDER=s3

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/Tasveer_Hubs?retryWrites=true&w=majority

# AWS S3 / CloudFront
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-Tasveer_Hubs-bucket
AWS_CLOUDFRONT_URL=https://your-distribution.cloudfront.net
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_SESSION_TOKEN=
